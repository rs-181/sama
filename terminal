# Function to open URL based on OS
open_url() {
    url="$1"
    case "$(uname -s)" in
        Linux*)  xdg-open "$url" 2>/dev/null || sensible-browser "$url" 2>/dev/null || echo "Please open: $url" ;;
        Darwin*) open "$url" 2>/dev/null ;;
        CYGWIN*|MINGW*|MSYS*) start "" "$url" 2>/dev/null || cmd.exe /c start "" "$url" 2>/dev/null ;;
        *)       echo "Please open manually: $url" ;;
    esac
}

